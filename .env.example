# =========================================================================
# Files Fly — Environment Variables
# =========================================================================
# Copy this file to ".env" and fill in your own values.
# cp .env.example .env
# =========================================================================

# -------------------------------------------------------------------------
# PostgreSQL Database Connection
# -------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# When using Docker, "postgres" is the service name from docker-compose.
# For local PostgreSQL, use "localhost".
DATABASE_URL=postgresql://filesfly:filesfly_secret@localhost:5432/filesfly

# -------------------------------------------------------------------------
# JWT Secret — Admin Login Signing Key
# -------------------------------------------------------------------------
# Used to sign JWT tokens issued when logging into the admin panel.
# Uses HMAC-SHA256 algorithm.
# YOU MUST CHANGE THIS VALUE! It should be a long random string.
# Generate one with: openssl rand -base64 64
# Never use the default "changeme-in-production" in production!
JWT_SECRET=changeme-in-production

# -------------------------------------------------------------------------
# IP Hash Secret — IP Address Anonymization Key
# -------------------------------------------------------------------------
# User IP addresses are never stored in plaintext in the database.
# They are hashed with SHA-256 HMAC using this secret as the key.
#
# IMPORTANT: If you leave this EMPTY, a random secret is generated on
# every server restart. This means:
#   - All IP hashes change (old hashes become invalid)
#   - Admin IP bans are effectively reset (hashes no longer match)
#   - The ip_hash column on existing files no longer maps to real IPs
#
# In production, YOU MUST SET THIS TO A FIXED STRING!
# Generate one with: openssl rand -base64 64
# If you change this value later, all existing bans and IP mappings break.
IP_HASH_SECRET=

# -------------------------------------------------------------------------
# Server Settings
# -------------------------------------------------------------------------
# PORT: The port the server listens on (default: 9392)
PORT=9392

# HOST: 0.0.0.0 = accessible from all network interfaces (required for Docker)
HOST=0.0.0.0

# NODE_ENV: "development" or "production"
#   - development: HSTS header DISABLED, more verbose logging
#   - production:  HSTS header ENABLED, full security headers
NODE_ENV=development

# BASE_URL: Base URL used when generating download links
# In production, set this to your actual domain (e.g. https://filesfly.example.com)
BASE_URL=http://localhost:9392

# -------------------------------------------------------------------------
# File Storage
# -------------------------------------------------------------------------
# Directory where uploaded files are stored.
# Docker: /data/uploads (mounted via docker-compose volume)
# Local:  ./uploads (inside the project directory)
UPLOADS_DIR=./uploads

# -------------------------------------------------------------------------
# Admin Seed — For Initial Setup (used by seed.js)
# -------------------------------------------------------------------------
# When seed.js runs, it creates an admin user with these credentials.
# You can remove these from .env after the initial setup.
# CHANGE THE PASSWORD!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
