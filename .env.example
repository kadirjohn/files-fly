# =========================================================================
# Files Fly — Environment Variables
# =========================================================================
# Copy this file to ".env" and fill in your own values.
# cp .env.example .env
# =========================================================================

# -------------------------------------------------------------------------
# PostgreSQL Database Connection
# -------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# When using Docker, "postgres" is the service name from docker-compose.
# For local PostgreSQL, use "localhost".
DATABASE_URL=postgresql://filesfly:filesfly_secret@localhost:5432/filesfly

# -------------------------------------------------------------------------
# JWT Secret — Admin Login Signing Key
# -------------------------------------------------------------------------
# Used to sign JWT tokens issued when logging into the admin panel.
# Uses HMAC-SHA256 algorithm.
# YOU MUST CHANGE THIS VALUE! It should be a long random string.
# Generate one with: openssl rand -base64 64
# Never use the default "changeme-in-production" in production!
JWT_SECRET=changeme-in-production

# -------------------------------------------------------------------------
# IP Hash Secret — IP Address Anonymization Key
# -------------------------------------------------------------------------
# User IP addresses are never stored in plaintext in the database.
# They are hashed with SHA-256 HMAC using this secret as the key.
#
# IMPORTANT: If you leave this EMPTY, a random secret is generated on
# every server restart. This means:
#   - All IP hashes change (old hashes become invalid)
#   - Admin IP bans are effectively reset (hashes no longer match)
#   - The ip_hash column on existing files no longer maps to real IPs
#
# In production, YOU MUST SET THIS TO A FIXED STRING!
# Generate one with: openssl rand -base64 64
# If you change this value later, all existing bans and IP mappings break.
IP_HASH_SECRET=

# -------------------------------------------------------------------------
# Server Settings
# -------------------------------------------------------------------------
# PORT: The port the server listens on (default: 9392)
PORT=9392

# HOST: 0.0.0.0 = accessible from all network interfaces (required for Docker)
HOST=0.0.0.0

# NODE_ENV: "development" or "production"
#   - development: HSTS header DISABLED, more verbose logging
#   - production:  HSTS header ENABLED, full security headers
NODE_ENV=development

# BASE_URL: Base URL used when generating download links
# In production, set this to your actual domain (e.g. https://filesfly.example.com)
BASE_URL=http://localhost:9392

# =========================================================================
# Object Storage / Bucket Configuration
# =========================================================================
# Files Fly supports pluggable storage backends. The active backend is selected
# via the `storage_backend` config key (set in admin panel) or the
# STORAGE_BACKEND env var below (fallback). The DB stores only the object key
# + backend per file, never the file bytes — this is the "Bucket" pattern.
#
# STORAGE_BACKEND: 'local' | 'r2' | 'supabase'   (default: 'local')
#   - local   : files on server disk (UPLOADS_DIR). Zero extra config.
#   - r2      : Cloudflare R2 bucket (S3-compatible). Requires R2_* env vars.
#   - supabase: Supabase Storage bucket (S3-compatible). Requires SUPABASE_* env vars.
#
# Cloud backends need the AWS SDK v3 packages (optionalDependencies in
# package.json): @aws-sdk/client-s3, @aws-sdk/lib-storage, @aws-sdk/s3-request-presigner
# Install them with: npm install
# If they are missing, the server falls back to 'local' and warns.
STORAGE_BACKEND=local

# -------------------------------------------------------------------------
# Local Disk Storage (used when STORAGE_BACKEND=local)
# -------------------------------------------------------------------------
# Directory where uploaded files are stored.
# Docker: /data/uploads (mounted via docker-compose volume)
# Local:  ./uploads (inside the project directory)
UPLOADS_DIR=./uploads

# Chunk assembly temp directory (always local, even with cloud backends —
# chunks are collected locally then uploaded to the bucket as one file).
# Defaults to <UPLOADS_DIR>/tmp if not set.
# CHUNK_TMP_DIR=./uploads/tmp

# -------------------------------------------------------------------------
# Cloudflare R2 Storage (used when STORAGE_BACKEND=r2)
# -------------------------------------------------------------------------
# Get these from Cloudflare Dashboard → R2 → (bucket) → Settings → S3 API.
# R2_ACCOUNT_ID:      your Cloudflare account ID
# R2_ACCESS_KEY_ID:   generated R2 API token access key
# R2_SECRET_ACCESS_KEY: generated R2 API token secret
# R2_BUCKET_NAME:     bucket name
# R2_PUBLIC_BASE_URL: (optional) https://<account>.r2.dev or custom domain —
#                     for public buckets; if set, public reads bypass presigned URLs
# R2_PRESIGN_EXPIRES_IN: (optional) presigned URL lifetime in seconds (default 3600)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
R2_PRESIGN_EXPIRES_IN=3600

# -------------------------------------------------------------------------
# Supabase Storage (used when STORAGE_BACKEND=supabase)
# -------------------------------------------------------------------------
# Get these from Supabase Dashboard → Project → Storage → S3 Connection.
# SUPABASE_S3_ENDPOINT:        https://<project>.supabase.co/storage/v1/s3
# SUPABASE_S3_REGION:          usually "us-east-1" (check Supabase docs)
# SUPABASE_S3_ACCESS_KEY_ID:   generated S3 access key
# SUPABASE_S3_SECRET_ACCESS_KEY: generated S3 secret
# SUPABASE_S3_BUCKET:          bucket name (created in Supabase Storage)
# SUPABASE_S3_PUBLIC_BASE_URL: (optional) https://<project>.supabase.co/storage/v1/object/public/
# SUPABASE_PRESIGN_EXPIRES_IN: (optional) presigned URL lifetime in seconds (default 3600)
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_BUCKET=
SUPABASE_S3_PUBLIC_BASE_URL=
SUPABASE_PRESIGN_EXPIRES_IN=3600

# -------------------------------------------------------------------------
# Admin Seed — For Initial Setup (used by seed.js)
# -------------------------------------------------------------------------
# When seed.js runs, it creates an admin user with these credentials.
# You can remove these from .env after the initial setup.
# CHANGE THE PASSWORD!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
